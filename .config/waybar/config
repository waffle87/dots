{
  "position": "top",
  "output": "DP-3",
  "modules-left": ["custom/power", "custom/switch-output", "memory", "cpu", "temperature"],
  "modules-center": ["sway/workspaces"],
  "modules-right": ["network", "pulseaudio", "custom/date", "clock"],
  "sway/workspaces": {
    "all-outputs": true,
    "format": "{icon}",
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
    },
    "format-icons": {
      "1": "五",
      "2": "六",
      "3": "七",
      "4": "八",
      "5": "九",
      }
  },
  "custom/date": {
    "format": "  {}",
    "interval": 60,
    "exec": "~/.config/scripts/date.sh"
  },
  "clock": {
    "format": "  {:%H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  },
  "network": {
    "format-wifi": " {ipaddr}/{cidr}",
    "format-ethernet": "  neptune",
    "format-disconnected": "  Disconnected",
    "format-alt": "  {essid}",
    "tooltip-format-wifi": "  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\n {bandwidthUpBits}  {bandwidthDownBits}",
    "tooltip-format-ethernet": " {ifname}\nIP: {ipaddr}\n {bandwidthUpBits}  {bandwidthDownBits}"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": " muted",
    "format-icons": {
      "headphone": "",
      "default": ["", ""]
    },
    "on-click": "pactl set-sink-mute 0 toggle"
  },
  "memory": {
    "format": " {}%"
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
    "critical-threshold": 85,
    "format-critical": " {temperatureC}°C",
    "format": " {temperatureC}°C",
  },
  "cpu": {
    "format": " {usage}%"
  },
  "custom/power": {
    "format": "",
    "on-click": "~/.config/scripts/power.sh"
  },
  "custom/switch-output": {
    "format": "",
    "on-click": "~/.config/scripts/output.sh"
  }
}
