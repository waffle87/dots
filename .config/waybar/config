{
  "layer": "top",
  "position": "bottom",
  "output": "DP-1",
  "modules-left": ["custom/power", "custom/switch-output", "memory", "cpu", "temperature"],
  "modules-center": ["custom/media"],
  "modules-right": ["network", "pulseaudio", "custom/date", "clock"],
  "sway/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "default": "",
    }
  },
  "custom/date": {
    "format": " {}",
    "interval": 60,
    "exec": "~/.config/scripts/date.sh"
  },
  "clock": {
    "format": " {:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#002b36'><b>{}</b></span>",
        "days": "<span color='#073642'><b>{}</b></span>",
        "weeks": "<span color='#b58900'><b>W{}</b></span>",
        "weekdays": "<span color='#859900'><b>{}</b></span>",
        "today": "<span color='#dc322f'><b><u>{}</u></b></span>"
      }
    },
    "actions":  {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "network": {
    "format-wifi": "  {ipaddr}/{cidr}",
    "format-ethernet": "  neptune",
    "format-disconnected": "󱚼  Disconnected",
    "format-alt": " {essid}",
    "tooltip-format-wifi": "  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\n {bandwidthUpBits}  {bandwidthDownBits}",
    "tooltip-format-ethernet": " {ifname}\nIP: {ipaddr}\n {bandwidthUpBits}  {bandwidthDownBits}"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": " muted",
    "format-icons": {
      "headphone": "",
      "default": ["", ""]
    },
    "on-click": "pactl set-sink-mute 0 toggle"
  },
  "memory": {
    "format": " {}%"
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
    "critical-threshold": 85,
    "format-critical": " {temperatureC}°C",
    "format": " {temperatureC}°C",
  },
  "cpu": {
    "format": " {usage}%"
  },
  "custom/power": {
    "format": "",
    "on-click": "~/.config/scripts/power.sh"
  },
  "custom/switch-output": {
    "format": "",
    "on-click": "~/.config/scripts/output.sh"
  },
  "custom/media": {
    "format": "{icon} {}",
    "escape": true,
    "return-type": "json",
    "max-length": 40,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "exec": "~/.config/scripts/mediaplayer.py 2> /dev/null",
  }
}
