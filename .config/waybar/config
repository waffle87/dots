    "tooltip-format-ethernet": "’ć½ {ifname}\nIP: {ipaddr}\n’éō {bandwidthUpBits} ’ĆÖ {bandwidthDownBits}"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
