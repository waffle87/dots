// Icons and Font - https://fontawesome.com/
{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // Module order
    "modules-left": [ "clock", "custom/eth", "network", "custom/weather"],
    "modules-center": ["sway/workspaces"],
    "modules-right": [ "memory", "temperature", "pulseaudio", "battery"],
    
    // Modules configuration
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "<span color=\"#88c0d0\">пЂ‚</span>",
            "2": "<span color=\"#88c0d0\">п„ </span>",
            "3": "<span color=\"#88c0d0\">п„Ў</span>",
            "4": "<span color=\"#88c0d0\">п‰є</span>",
            "5": "<span color=\"#88c0d0\">п…њ</span>",
            "6": "<span color=\"#88c0d0\">п…„</span>",
        }
    },
    "sway/window": {
        "format": "{}",
        "max-length": 50, 
        "tooltip": false
    },
    "tray": {
        "spacing": 5
    },
    "clock": {
        "format": "<span color=\"#bf616a\">пЂ—</span>  {:%H:%M  <span color=\"#bf616a\">пЃі</span> %e %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "today-format": "<b>{}</b>",
    },
    "cpu": {
        "interval": "1",      
        "format": "п‹›  {max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
        "max-length": 13,
        "min-length": 13,
        "tooltip": false
    },  
    "memory": {
        "format": "<span color=\"#a3be8c\">п‡Ђ</span> {}%"
    },
    "temperature": {
        //"thermal-zone": 1,
        "interval": "4",
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon6/temp1_input",
        "critical-threshold": 80,
        "format-critical": "пЃ±  {temperatureC}В°C",
        "format": "<span color=\"#b48ead\">{icon}</span>  {temperatureC}В°C",
        "format-icons": ["п‹‰"],
        "max-length": 7,
        "min-length": 7
    },
    "network": {
        // "interface": "wlan0", // (Optional) To force the use of this interface,
        "format-wifi": "<span color=\"#ebcb8b\">п‡«</span>  {essid}",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} п›ї",
        "format-linked": "{ifname} (No IP) пћ–",
        "format-disconnected": "пЃ—",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "family": "ipv4",
        "tooltip-format-wifi": "п‡«  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nп‚“ {bandwidthUpBits} пЂ™ {bandwidthDownBits}",
        "tooltip-format-ethernet": "п›ї {ifname}\nIP: {ipaddr}\nп‚“ {bandwidthUpBits} пЂ™ {bandwidthDownBits}"
    },
    "pulseaudio": {
        "scroll-step": 3, // %, can be a float
        "format": "<span color=\"#5e81ac\">{icon}</span> {volume}%",
        "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
        "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
        "format-muted": "пљ© {format_source}",
        //"format-source": "{volume}% п„°",
        //"format-source-muted": "п„±",
        //"format-source": "п„°",
        //"format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pactl set-sink-mute 0 toggle"
    },

    "battery": {
        "states": {
            //"good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{capacity}% <span color=\"#8fbcbb\">{icon}</span>",
        "format-charging": "{capacity}% п—§",
        "format-plugged": "{capacity}% п‡¦",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
    
    // custom modules
    "custom/weather": {
        "exec": "curl 'https://wttr.in/?format=1'",
        "interval": 1800
    },
    "custom/power": {
        "format": "пЂ‘",
        "interval": "once",
        "on-click": "./.config/waybar/pm.sh"
    },
    "custom/eth": {
        "format": "<span color=\"#d08770\">п‚Ђ</span> {}",
        "exec": "$HOME/.config/waybar/eth.sh", 
        "interval": 600
    },
    "custom/media": {
    "format": "{icon} {}",
    "return-type": "json",
    "max-length": 25,
    "format-icons": {
        "spotify": "п†ј",
        "default": "рџЋњ"
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
    // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}
