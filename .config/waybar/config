  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
    "critical-threshold": 85,
    "format-critical": "’ü▒ {temperatureC}┬░C",
    "format": "’ŗē {temperatureC}┬░C",
