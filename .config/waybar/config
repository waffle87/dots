  },
  "custom/switch-output": {
    "format": "’æ¬",
    "on-click": "~/.config/scripts/output.sh"
  },
  "custom/media": {
    "format": "{icon} {}",
    "escape": true,
    "return-type": "json",
    "max-length": 40,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "exec": "~/.config/scripts/mediaplayer.py 2> /dev/null",
  },
  "hyprland/workspaces": {
