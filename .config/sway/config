# desktop
default_border pixel 3
default_floating_border pixel 3
gaps inner 9

# class                 border  bground text    indicator child_border
client.focused          #586e75 #586e75 #fdf6e3 #586e75   #586e75
client.unfocused        #073642 #073642 #fdf6e3 #073642   #073642
client.focused_inactive #073642 #073642 #fdf6e3 #073642   #073642
client.urgent           #dc322f #dc322f #fdf6e3 #dc322f   #dc322f

set $mod Mod4
set $left h
set $down j
set $up k
set $right l

output DP-3 pos 0 395  bg ~/.img/wallpaper/parkinglot.png fill res 1920x1080
output DP-2 pos 1920 0 bg ~/.img/wallpaper/ferris.png     fill transform 270
output DP-1 pos 3000 0 bg ~/.img/wallpaper/ferris.png     fill transform 270
focus output DP-3

exec /usr/bin/mako
exec /usr/bin/easyeffects --gapplication-service

input type:keyboard {
  xkb_layout us,ru
  xkb_options grp:alts_toggle
}

set $gnome-schema org.gnome.desktop.interface
exec_always {
  gsettings set $gnome-schema gtk-theme 'Solarized-Dark'
  gsettings set $gnome-schema cursor-theme 'Rumia'
}

### key bindings 
# applications
bindsym $mod+q kill
bindsym $mod+t exec       alacritty
bindsym $mod+f exec       firefox
bindsym $mod+r exec       wofi --show run --lines=7
bindsym $mod+p exec       grim -g "$(slurp)" - | wl-copy
bindsym $mod+Shift+p exec grim -g "$(slurp)"

# audio
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioPlay        exec playerctl play-pause
bindsym XF86AudioNext        exec playerctl next
bindsym XF86AudioPrev        exec playerctl previous

# reload configuration file
bindsym $mod+Shift+c reload
# exit wayland session
bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -b 'Yes, exit sway' 'swaymsg exit'

# change focused container 
bindsym $mod+$left  focus left
bindsym $mod+$down  focus down
bindsym $mod+$up    focus up
bindsym $mod+$right focus right
# move focused window
bindsym $mod+Shift+$left  move left
bindsym $mod+Shift+$down  move down
bindsym $mod+Shift+$up    move up
bindsym $mod+Shift+$right move right
# move focused window to another monitor
bindsym $mod+Control+$right move container to output right
bindsym $mod+Control+$left  move container to output left
bindsym $mod+Control+$down  move container to output down
bindsym $mod+Control+$up    move container to output up

# drag floating windows: $mod + left mouse button
floating_modifier $mod normal

# change whether windows open horizontally or
# vertically to currently open windows, respectively
bindsym $mod+b splith
bindsym $mod+v splitv

# switch focused container between different layouts
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# make focused window fullscreen
bindsym $mod+Shift+f fullscreen

# toggle focused window between floating and tiling
bindsym $mod+Shift+space floating toggle

# switch focus between tiling and floating windows
bindsym $mod+space focus mode_toggle

# scratchpad: bag for holding windows (like minimize)
# move focused window to scratchpad
bindsym $mod+n move scratchpad

# cycle through windows in scratchpad
bindsym $mod+Shift+n scratchpad show

bar {
  swaybar_command waybar
}

include /etc/sway/config.d/*
